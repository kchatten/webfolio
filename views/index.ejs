<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Under Construction</title>
</head>
<body>
    <style>
        body{
            background-image: url(https://www.freevector.com/uploads/vector/preview/4951/FreeVector-Under-Construction-Graphics.jpg);
            background-size:cover;
            width: 100%;
            height: 100%;
            margin: 0 !important;
        }
        /* Styling for the overlay */
        #overlay {
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background-color: rgba(0, 0, 0, 0.5); /* Semi-transparent black */
          z-index: 9999; /* Ensure it's on top of other elements */
          display: none; /* Initially hidden */
        }
      
        /* Styling for the content in the overlay */
        #overlay-content {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        background-color: white; /* White background */
        padding: 20px;
        border-radius: 10px; /* Rounded corners */
        max-width: 300px;
        } 

        #overlay-text {
            font-weight: bolder;
            font-size: larger;
            font-family: Tahoma, sans-serif;
        }
      </style>    
</head>
      
    <div id="overlay">
        <div id="overlay-content">
            <p id="overlay-text">Hello! Thank you for your interest in my webfolio. I am currently quite busy with my studies but I am hard at work trying to update this as soon as possible. Thank you for your patience! - kChat</p>
        </div>
    </div>
      
    <script>
        function showOverlay() {
          document.getElementById("overlay").style.display = "block";
        }
      
        // Commented out for later use.
        // function closeOverlay() {
        //   document.getElementById("overlay").style.display = "none";
        // }
      
        showOverlay();

    </script>
</body>
</html>